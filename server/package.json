{
  "name": "@hospital/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "create:admin": "node scripts/create-admin.js",
    "db:seed-exams": "ts-node -r dotenv/config scripts/seed-exams.ts dotenv_config_path=.env",
    "db:assign-random-videos": "ts-node -r dotenv/config scripts/assign-random-cloudflare-videos.ts dotenv_config_path=.env",
    "db:sync-lesson-videos": "ts-node -r dotenv/config scripts/sync-lesson-videos.ts dotenv_config_path=.env",
    "db:firebase-migrate": "ts-node -r dotenv/config scripts/firebase-migrate.ts dotenv_config_path=.env",
    "db:migrate-videos": "ts-node -r dotenv/config scripts/migrate-videos.ts dotenv_config_path=.env",
    "db:deduplicate-plans": "ts-node -r dotenv/config scripts/deduplicate-plans.ts dotenv_config_path=.env",
    "db:cleanup-stream": "ts-node -r dotenv/config scripts/cleanup-stream.ts dotenv_config_path=.env",
    "export:convert-dump": "ts-node scripts/convert-firestore-dump.ts",
    "export:live": "ts-node -r dotenv/config scripts/export-firestore.ts",
    "export:live:sa": "ts-node -r dotenv/config scripts/export-firestore.ts dotenv_config_path=.env",
    "export:parse-backup": "ts-node scripts/parse-firestore-backup.ts",
    "export:rest": "ts-node scripts/export-rest.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@fastify/static": "^7.0.4",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^10.4.15",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-kit": "^0.30.4",
    "drizzle-orm": "^0.38.3",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.4.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.1.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "stripe": "^17.5.0",
    "tus-js-client": "^4.3.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.11.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
