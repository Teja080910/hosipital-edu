{
  "name": "hospital-edu",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:client": "pnpm --filter @hospital/client dev",
    "dev:server": "pnpm --filter @hospital/server dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:generate": "pnpm --filter @hospital/server db:generate",
    "db:migrate": "pnpm --filter @hospital/server db:migrate",
    "db:push": "pnpm --filter @hospital/server db:push",
    "db:studio": "pnpm --filter @hospital/server db:studio"
  },
  "engines": {
    "node": ">=20.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "@nestjs/core", "esbuild", "msgpackr-extract", "@swc/core"]
  }
}